@page "/"
@implements IDisposable
@inject RouteAnalysisService Analysis
@inject IJSRuntime JS

<PageTitle>Laadinfrastructuur Planner</PageTitle>

<div class="planner-shell">
    <aside class="planner-sidebar">
        <div class="brand-block">
            <div class="brand-mark">LI</div>
            <div>
                <h1>Laadinfrastructuur Planner</h1>
                <p>Depot- en corridoranalyse</p>
            </div>
        </div>

        <section class="filter-group">
            <label>Vervoersvorm</label>
            <div class="segmented">
                <button class="@ModeClass("Alles")" @onclick='() => SetTransportModeAsync("Alles")' disabled="@IsBusy">Alles</button>
                <button class="@ModeClass("Eigen")" @onclick='() => SetTransportModeAsync("Eigen")' disabled="@IsBusy">Eigen</button>
                <button class="@ModeClass("Charter")" @onclick='() => SetTransportModeAsync("Charter")' disabled="@IsBusy">Charter</button>
            </div>
        </section>

        <section class="filter-grid">
            <label>
                Datum vanaf
                <input type="date" value="@DateFromText" @onchange="e => DateFromText = e.Value?.ToString() ?? string.Empty" />
            </label>
            <label>
                Datum tot
                <input type="date" value="@DateToText" @onchange="e => DateToText = e.Value?.ToString() ?? string.Empty" />
            </label>
            <label>
                Vervoerders
                <input placeholder="namen scheiden met komma's" @bind="VervoerdersText" />
            </label>
            <label>
                Voertuigen of kentekens
                <input placeholder="wagen-codes of kentekens" @bind="WagencodesText" />
            </label>
            <label>
                Min. stopduur (min)
                <input type="number" min="0" max="180" step="5" @bind="MinDwellMin" />
            </label>
            <label>
                ZE-zones
                <select @bind="ZeZoneMode">
                    <option value="all">Alle ritten en stops</option>
                    <option value="in">Alleen in ZE-zone</option>
                    <option value="out">Alleen buiten ZE-zone</option>
                </select>
            </label>
            <label>
                Min. passages per wegvlak
                <input type="number" min="1" max="1000000" step="50" @bind="RoadThreshold" />
                <input class="range-control" type="range" min="1" max="5000" step="25" @bind="RoadThreshold" @bind:event="oninput" />
            </label>
            <label>
                Zichtbare wegdata
                <input type="number" min="1" max="25" step="1" @bind="RoadTopPercent" />
                <input class="range-control" type="range" min="1" max="25" step="1" @bind="RoadTopPercent" @bind:event="oninput" />
                <span class="range-value">@RoadTopPercent% van beschikbare wegpunten en wegvlakken</span>
            </label>
        </section>

        <section class="filter-group">
            <label>Kaartlagen</label>
            <label class="toggle"><input type="checkbox" @bind="ShowStopHeat" @bind:after="RefreshMapAsync" /> Stopdrukte</label>
            <label class="toggle"><input type="checkbox" @bind="ShowMarkers" @bind:after="RefreshMapAsync" /> Toplocaties</label>
            <label class="toggle"><input type="checkbox" @bind="ShowRoads" @bind:after="RefreshMapAsync" /> Wegvlakken</label>
            <label class="toggle"><input type="checkbox" @bind="ShowRoadHeat" @bind:after="RefreshMapAsync" /> Wegdrukte</label>
            <label class="toggle"><input type="checkbox" @bind="ShowOvernight" @bind:after="RefreshMapAsync" /> Vaste stilstandlocaties</label>
            <label class="toggle"><input type="checkbox" @bind="ShowStandplaatsen" @bind:after="RefreshMapAsync" /> Standplaatsen (PostNL-wagenpark)</label>
            <label class="toggle"><input type="checkbox" @bind="ShowChargers" @bind:after="RefreshMapAsync" /> Laadlocaties</label>
            <p class="hint-text">Wegvlakken zijn klikbare lijnsegmenten voor detailanalyse. Wegdrukte is een vloeiende heatmap van passages op het wegennet.</p>
            @if (ShowStandplaatsen)
            {
                <p class="hint-text disclaimer">Standplaatsen zijn ruw gegeocodeerd op plaatsnaam; markers kunnen afwijken van het werkelijke adres.</p>
            }
        </section>

        <section class="filter-grid demand-controls">
            <label>
                Min. voertuigen per depot
                <input type="number" min="1" max="100" step="1" @bind="MinDepotVehicles" />
            </label>
            <label>
                kWh/km
                <input type="number" min="0.5" max="3.5" step="0.1" @bind="ScenarioKwhPerKm" />
            </label>
            <label>
                Batterijcapaciteit (kWh)
                <input type="number" min="100" max="1500" step="10" @bind="ScenarioCapacityKwh" @bind:after="RefreshPowerProfilesAsync" />
            </label>
            <label class="toggle mcs-toggle"><input type="checkbox" @bind="ScenarioMcsEnabled" @bind:after="RefreshPowerProfilesAsync" /> MCS laden toestaan</label>
            <span class="range-value">Max. afname per truck: @MaxVehicleKw.ToString("N0") kW</span>
            <label>
                Doel laadniveau (%)
                <input type="number" min="20" max="100" step="5" @bind="ScenarioTargetSocPct" />
            </label>
            <label>
                Vermogen per stekker (kW)
                <input type="number" min="50" max="2000" step="50" @bind="ScenarioKwPerPlug" />
            </label>
            <label>
                Stekkers
                <input type="number" min="1" max="100" step="1" @bind="ScenarioPlugs" />
            </label>
            <label>
                Locatielimiet (MW)
                <input type="number" min="0.05" max="50" step="0.1" @bind="ScenarioSiteLimitMw" />
            </label>
        </section>

        <section class="filter-grid charger-controls">
            <label>
                Min. vermogen (kW)
                <input type="number" min="0" max="400" step="50" @bind="ChargerMinPowerKw" @bind:after="RefreshMapAsync" />
            </label>
            <label class="toggle"><input type="checkbox" @bind="ChargerOnlyDedicated" @bind:after="RefreshMapAsync" /> Alleen gereserveerd</label>
            <label class="toggle"><input type="checkbox" @bind="ChargerAccessPublic" @bind:after="RefreshMapAsync" /> Publiek</label>
            <label class="toggle"><input type="checkbox" @bind="ChargerAccessSemiPublic" @bind:after="RefreshMapAsync" /> Semi-publiek</label>
            <label class="toggle"><input type="checkbox" @bind="ChargerAccessPrivate" @bind:after="RefreshMapAsync" /> Privaat</label>
        </section>

        <button class="primary-action" @onclick="ApplyFiltersAsync" disabled="@IsBusy">
            @(IsBusy ? "Bijwerken..." : "Analyse bijwerken")
        </button>

        @if (Metadata is not null)
        {
            <div class="cache-status">
                <strong>Gegevens</strong>
                <span>@(Metadata.DataAvailable ? Metadata.DataSource : "Ritgegevens niet beschikbaar")</span>
                <span>@Metadata.StopCount.ToString("N0") stopmomenten</span>
            </div>
        }

        <section class="upload-panel">
            <div>
                <strong>Eigen dataset</strong>
                <span>CSV of parquet met ritregels</span>
            </div>
            <InputFile OnChange="UploadDatasetAsync" multiple accept=".csv,.parquet" />
            <p>CSV gebruikt bij voorkeur kolommen voor voertuig, rit, start/eind, afstand en lat/lon. Zonder lat/lon is een locatiekoppeling nodig.</p>
            @if (IsUploading)
            {
                <span class="upload-status">Dataset verwerken...</span>
            }
            else if (UploadResult is not null)
            {
                <span class="upload-status @(UploadResult.Success ? "ok" : "error")">@UploadResult.Message</span>
            }
        </section>
    </aside>

    <main class="planner-main">
        <header class="planner-header">
            <div>
                <p class="section-label">Route-analyse</p>
                <h2>Laadvraag per depot en druk wegvlak</h2>
            </div>
            <div class="header-status @(Metadata?.DataAvailable == true ? "ok" : "missing")">
                @(Metadata?.DataAvailable == true ? "Gegevens geladen" : "Gegevens ontbreken")
            </div>
        </header>

        @if (Metadata?.DataAvailable != true)
        {
            <section class="empty-state">
                <h3>Geen ritgegevens gevonden</h3>
                <p>Controleer of de ritbestanden en locatiegegevens beschikbaar zijn.</p>
            </section>
        }

        <section class="metric-row">
            <div class="metric"><span>Stopmomenten</span><strong>@FormatNumber(Summary?.Stops)</strong></div>
            <div class="metric"><span>Dagritten</span><strong>@FormatNumber(Summary?.Trips)</strong></div>
            <div class="metric"><span>Voertuigen</span><strong>@FormatNumber(Summary?.Wagens)</strong></div>
            <div class="metric"><span>Totale km</span><strong>@FormatNumber(Summary?.TotalKm)</strong></div>
            <div class="metric"><span>Stopduur (uur)</span><strong>@FormatNumber(Summary?.TotalDwellHours)</strong></div>
        </section>

        @if (PowerProfiles is not null)
        {
            <section class="table-panel power-profile-panel">
                <div class="panel-heading">
                    <div>
                        <h3>24-uurs vermogensprofiel</h3>
                        <span>@PowerTransportLabel · klik op een cel voor voertuigen</span>
                    </div>
                    <button @onclick="RefreshPowerProfilesAsync" disabled="@IsBusy">Profiel bijwerken</button>
                </div>
                @if (!string.IsNullOrWhiteSpace(PowerProfiles.Message))
                {
                    <p class="selection-message">@PowerProfiles.Message</p>
                }
                else
                {
                    <div class="power-method-strip">
                        <strong>Berekening</strong>
                        <span>Per truck: @ScenarioCapacityKwh.ToString("N0") kWh / stilstanduren, begrensd op @MaxVehicleKw.ToString("N0") kW voertuigacceptatie. Cellen tonen de hoogste uurpiek in de selectie.</span>
                    </div>
                    <div class="power-heatmap" aria-label="Standplaats per uur vermogensvraag">
                        <div class="power-grid-corner"></div>
                        @foreach (var hour in Enumerable.Range(0, 24))
                        {
                            <span class="power-hour-label">@($"{hour:00}")</span>
                        }
                        @foreach (var profile in PowerProfiles.Locations.Take(5))
                        {
                            <button class="power-location-label" title="@profile.Address" @onclick="() => SelectPowerLocationAsync(profile.LocationId)">
                                @(string.IsNullOrWhiteSpace(profile.Name) ? profile.Address : profile.Name)
                            </button>
                            @foreach (var cell in profile.HourlyProfile.OrderBy(x => x.Hour))
                            {
                                <button class="power-cell"
                                        style="@PowerCellStyle(cell.RequiredKw, PowerProfiles.Locations)"
                                        title="@($"{cell.Label}: {FormatPower(cell.RequiredKw)} · {cell.Vehicles:N0} voertuigen")"
                                        @onclick="() => OpenPowerDemandPopupAsync(profile, cell)">
                                    <span>@(cell.RequiredKw > 0 ? FormatPower(cell.RequiredKw) : "")</span>
                                </button>
                            }
                        }
                    </div>
                    <div class="power-profile-summary">
                        @foreach (var profile in PowerProfiles.Locations.Take(5))
                        {
                            <button class="power-summary-row" @onclick="() => SelectPowerLocationAsync(profile.LocationId)">
                                <strong>@(string.IsNullOrWhiteSpace(profile.Name) ? profile.Address : profile.Name)</strong>
                                <span>@FormatPower(profile.PeakKw) piek</span>
                                <span>@profile.UniqueOwnVehicles.ToString("N0") eigen · @profile.UniqueCharterVehicles.ToString("N0") charter</span>
                            </button>
                        }
                    </div>
                }
                @if (PowerDiagnostics is not null)
                {
                    <p class="power-diagnostics">
                        Datakwaliteit: @PowerDiagnostics.ChargeWindowActions.ToString("N0") laadvensters,
                        @PowerDiagnostics.MissingLocationActions.ToString("N0") zonder bruikbare locatie,
                        @PowerDiagnostics.UnknownVehicleClassActions.ToString("N0") zonder eigen/charter-label.
                    </p>
                }
            </section>
        }

        @if (SelectedPowerProfile is not null)
        {
            <section class="selection-panel compact-selection">
                <div class="panel-heading">
                    <div>
                        <h3>@(SelectedPowerProfile.Profile?.Name ?? "Standplaatsprofiel")</h3>
                        <span>Drill-down vermogensprofiel</span>
                    </div>
                </div>
                @if (SelectedPowerProfile.Profile is not null)
                {
                    var profile = SelectedPowerProfile.Profile;
                    <div class="metric-row compact">
                        <div class="metric"><span>Voertuigen</span><strong>@profile.UniqueVehicles.ToString("N0")</strong></div>
                        <div class="metric"><span>Eigen</span><strong>@profile.UniqueOwnVehicles.ToString("N0")</strong></div>
                        <div class="metric"><span>Charter</span><strong>@profile.UniqueCharterVehicles.ToString("N0")</strong></div>
                        <div class="metric"><span>Piek</span><strong>@FormatPower(profile.PeakKw)</strong></div>
                    </div>
                    <div class="window-list">
                        @foreach (var scenario in SelectedPowerProfile.Scenarios)
                        {
                            var peak = scenario.HourlyProfile.MaxBy(x => x.RequiredKw);
                            <div class="window-row">
                                <strong>@scenario.Year · @scenario.Mode</strong>
                                <span>factor @scenario.ScaleFactor.ToString("P0")</span>
                                <span>@(peak?.Label ?? "00:00")</span>
                                <span>@(peak is null ? "0 kW" : FormatPower(peak.RequiredKw))</span>
                            </div>
                        }
                    </div>
                    <div class="power-report-grid">
                        <div class="analysis-card power-report-card">
                            <div class="card-heading">
                                <strong>Uurprofiel huidige selectie</strong>
                                <span>@FormatPower(profile.HourlyProfile.Max(x => x.RequiredKw)) piek</span>
                            </div>
                            <div class="power-bars" aria-label="Uurprofiel geselecteerde standplaats">
                                @foreach (var hour in profile.HourlyProfile.OrderBy(x => x.Hour))
                                {
                                    <button class="power-bar"
                                            style="@PowerBarStyle(hour.RequiredKw, profile.HourlyProfile)"
                                            title="@($"{hour.Label}: {FormatPower(hour.RequiredKw)} · {hour.Vehicles:N0} voertuigen")"
                                            @onclick="() => OpenPowerDemandPopupAsync(profile, hour)">
                                        <span>@hour.Hour.ToString("00")</span>
                                        <i>@FormatPower(hour.RequiredKw)</i>
                                    </button>
                                }
                            </div>
                        </div>
                        <div class="analysis-card power-report-card">
                            <div class="card-heading">
                                <strong>Dagpieken voor rapport</strong>
                                <span>@SelectedPowerProfile.DailyMetrics.Length.ToString("N0") dagen</span>
                            </div>
                            <div class="table-scroll compact-scroll">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Datum</th>
                                            <th>Voertuigen</th>
                                            <th>Eigen</th>
                                            <th>Charter</th>
                                            <th>Gem. stilstand</th>
                                            <th>Piek</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var day in TopPowerDays(SelectedPowerProfile.DailyMetrics))
                                        {
                                            <tr>
                                                <td><strong>@day.Date.ToString("dd-MM-yyyy")</strong></td>
                                                <td>@day.UniqueVehicles.ToString("N0")</td>
                                                <td>@day.OwnVehicles.ToString("N0")</td>
                                                <td>@day.CharterVehicles.ToString("N0")</td>
                                                <td>@day.AvgDwellMin.ToString("N0") min</td>
                                                <td><strong>@FormatPower(day.PeakKw)</strong></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                }
            </section>
        }

        @if (Dashboard?.ZeZones.Length > 0)
        {
            <section class="table-panel ze-panel">
                <div class="panel-heading">
                    <h3>Zero-emissiezones</h3>
                    <span>@Dashboard.ZeZones.Length zones in selectie</span>
                </div>
                <div class="table-scroll">
                    <table>
                        <thead>
                            <tr>
                                <th>Zone</th>
                                <th>Startdatum</th>
                                <th>Stops</th>
                                <th>Ritten</th>
                                <th>Voertuigen</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var zone in Dashboard.ZeZones.Take(12))
                            {
                                <tr>
                                    <td><strong>@zone.Zone</strong></td>
                                    <td>@zone.StartDate</td>
                                    <td>@zone.Stops.ToString("N0")</td>
                                    <td>@zone.Trips.ToString("N0")</td>
                                    <td>@zone.Wagens.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
        else if (Metadata?.ZeZones.Length > 0 && ZeZoneMode == "in")
        {
            <section class="empty-state compact-empty">
                <h3>Geen stops in zero-emissiezone</h3>
                <p>Er zijn geen ZE-zone stops binnen de huidige filters.</p>
            </section>
        }

        <section class="map-panel">
            <div class="panel-heading">
                <h3>Kaart</h3>
                <span id="map-status">Klaar</span>
            </div>
            <div class="map-frame">
                <div id="route-map" class="route-map"></div>
                <aside class="map-legend @(LegendCollapsed ? "is-collapsed" : "")" aria-label="Legenda kaartlagen">
                    <div class="legend-heading">
                        <strong>Legenda</strong>
                        @if (!LegendCollapsed)
                        {
                            <span>Actieve lagen</span>
                        }
                        <button type="button"
                                class="legend-toggle"
                                title="@(LegendCollapsed ? "Legenda tonen" : "Legenda minimaliseren")"
                                aria-label="@(LegendCollapsed ? "Legenda tonen" : "Legenda minimaliseren")"
                                @onclick="() => LegendCollapsed = !LegendCollapsed">
                            @(LegendCollapsed ? "+" : "-")
                        </button>
                    </div>

                    @if (!LegendCollapsed && ShowStopHeat)
                    {
                        <div class="legend-item heat">
                            <span class="legend-gradient stop-gradient"></span>
                            <div>
                                <strong>Stopdrukte</strong>
                                <span>Blauw naar rood: van beperkte naar zeer hoge stopdrukte.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && ShowMarkers)
                    {
                        <div class="legend-item">
                            <span class="legend-symbol stop-marker"></span>
                            <div>
                                <strong>Toplocaties</strong>
                                <span>Blauwe rondjes met witte rand; groter betekent meer voertuigen.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && ShowChargers)
                    {
                        <div class="legend-item">
                            <span class="legend-symbol charger-marker"></span>
                            <div>
                                <strong>Laadlocaties</strong>
                                <span>Groene rondjes met witte rand; groter betekent hoger vermogen.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && ShowOvernight)
                    {
                        <div class="legend-item split">
                            <span class="legend-symbol overnight-ok"></span>
                            <span class="legend-symbol overnight-shortage"></span>
                            <div>
                                <strong>Vaste stilstandlocaties</strong>
                                <span>Geel: lokaal laden lijkt voldoende. Rood: verwacht laadtekort.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && ShowStandplaatsen)
                    {
                        <div class="legend-item">
                            <span class="legend-symbol standplaats-marker"></span>
                            <div>
                                <strong>Standplaatsen (wagenpark)</strong>
                                <span>Donkerblauwe rondjes met witte rand; groter betekent meer voertuigen op die standplaats. Klik voor voertuigenlijst.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && ShowRoads)
                    {
                        <div class="legend-item">
                            <span class="legend-line road-line"></span>
                            <div>
                                <strong>Wegvlakken</strong>
                                <span>Klikbare paarse lijnen. Filter gebruikt minimale passages; samengevoegd per rijrichting.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && ShowRoadHeat)
                    {
                        <div class="legend-item heat">
                            <span class="legend-gradient road-gradient"></span>
                            <div>
                                <strong>Wegdrukte</strong>
                                <span>Niet klikbare heatmap. Zelfde passagedrempel, maar als vloeiende concentratiekaart.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && SelectedDetail?.SelectionType == "stop")
                    {
                        <div class="legend-item heat">
                            <span class="legend-gradient selection-gradient"></span>
                            <div>
                                <strong>Vertrekroutes</strong>
                                <span>Groen naar rood: routes vanaf de gekozen stoplocatie na een vaste stilstandperiode.</span>
                            </div>
                        </div>
                    }
                </aside>
            </div>
        </section>

        @if (SelectedDetail is not null)
        {
            <section class="selection-panel">
                <div class="panel-heading">
                    <div>
                        <h3>@SelectedDetail.Title</h3>
                        <span>@SelectionTypeLabel(SelectedDetail.SelectionType)</span>
                    </div>
                    <button @onclick="RefreshSelectedDetailAsync" disabled="@IsBusy">Scenario bijwerken</button>
                </div>

                @if (!string.IsNullOrWhiteSpace(SelectedDetail.Message))
                {
                    <p class="selection-message">@SelectedDetail.Message</p>
                }

                <div class="metric-row compact">
                    <div class="metric"><span>Dagritten</span><strong>@FormatNumber(SelectedDetail.Summary.Trips)</strong></div>
                    <div class="metric"><span>Voertuigen</span><strong>@FormatNumber(SelectedDetail.Summary.UniqueVehicles)</strong></div>
                    <div class="metric"><span>Energievraag (MWh)</span><strong>@FormatNumber(SelectedDetail.Charging.TotalMwh)</strong></div>
                    <div class="metric"><span>Piekvraag (MW)</span><strong>@SelectedDetail.Charging.PeakMw.ToString("N2")</strong></div>
                </div>

                @if (SelectedDetail.SelectionType == "depot")
                {
                    var selectedDemand = SelectedWeeklyDemandCell();
                    <div class="analysis-card weekly-demand-card">
                        <div class="card-heading">
                            <strong>Piekprofiel vermogensvraag per weekuur</strong>
                            <span>@(selectedDemand is null ? "Geen stilstandvensters" : $"{selectedDemand.Label} · {selectedDemand.Vehicles:N0} voertuigen · {selectedDemand.RequiredKw:N0} kW")</span>
                        </div>
                        <div class="week-demand-heatmap" aria-label="Weekprofiel vermogensvraag">
                            <div class="week-grid-corner"></div>
                            @foreach (var hour in Enumerable.Range(0, 24))
                            {
                                <span class="week-hour-label">@($"{hour:00}")</span>
                            }
                            @foreach (var dayGroup in SelectedDetail.Charging.WeeklyProfile.GroupBy(x => new { x.DayIndex, x.DayLabel }).OrderBy(x => x.Key.DayIndex))
                            {
                                <strong class="week-day-label">@ShortDayLabel(dayGroup.Key.DayLabel)</strong>
                                @foreach (var cell in dayGroup.OrderBy(x => x.Hour))
                                {
                                    <button class="@WeekCellClass(cell)"
                                            style="@WeekCellStyle(cell)"
                                            title="@($"{cell.Label}: {cell.Vehicles:N0} voertuigen, {cell.RequiredKw:N0} kW gevraagd")"
                                            @onclick="() => OpenDemandPopup(cell)">
                                        <span>@cell.RequiredKw.ToString("N0")</span>
                                    </button>
                                }
                            }
                        </div>
                        <p class="week-demand-note">
                            @(EmptyWeekCellCount() == 0
                                ? "In de huidige selectie is elk week/uurblok minimaal één keer bezet; er zijn daarom geen 0 kW-blokken voor deze filters."
                                : "Grijze blokken zijn 0 kW: geen voertuigen aanwezig in dat week/uurblok.")
                        </p>
                        @if (selectedDemand is not null)
                        {
                            <div class="week-demand-detail">
                                <strong>@selectedDemand.Label</strong>
                                <span>@selectedDemand.RequiredKw.ToString("N0") kW gevraagd (@selectedDemand.RequiredMw.ToString("N2") MW)</span>
                                <span>@selectedDemand.Vehicles.ToString("N0") voertuigen aanwezig</span>
                                <span>Kentekens: @JoinValues(selectedDemand.Kentekens, "geen kentekens bekend")</span>
                                <span>Voertuigcodes: @JoinValues(selectedDemand.Wagencodes, "geen voertuigcodes bekend")</span>
                            </div>
                        }
                    </div>
                }

                <div class="selection-grid">
                    <div class="analysis-card">
                        <div class="card-heading">
                            <strong>Afstandsverdeling</strong>
                            <span>P95 @SelectedDetail.Distribution.P95Km.ToString("N0") km</span>
                        </div>
                        <div class="histogram">
                            @foreach (var bucket in SelectedDetail.Distribution.Buckets)
                            {
                                <div class="histogram-row">
                                    <span>@bucket.FromKm.ToString("N0")-@bucket.ToKm.ToString("N0")</span>
                                    <div><i style="width:@HistogramWidth(bucket.Trips, SelectedDetail.Distribution.Buckets)"></i></div>
                                    <b>@bucket.Trips</b>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="analysis-card">
                        <div class="card-heading">
                            <strong>Laadprofiel</strong>
                            <span>@SelectedDetail.Charging.Recommendation</span>
                        </div>
                        <div class="window-list">
                            @foreach (var window in SelectedDetail.Charging.BusyWindows)
                            {
                                <div class="window-row">
                                    <strong>@window.TimeSlot</strong>
                                    <span>@window.DemandKwh.ToString("N0") kWh nodig</span>
                                    <span>@window.ShortageKwh.ToString("N0") kWh tekort</span>
                                    <span>@window.RequiredMw.ToString("N2") MW</span>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="table-panel nested-table">
                    <div class="panel-heading">
                        <h3>Voertuigen in selectie</h3>
                        <span>@SelectedDetail.Vehicles.Length voertuigen</span>
                    </div>
                    <div class="table-scroll">
                        <table>
                            <thead>
                                <tr>
                                    <th>Kenteken(s)</th>
                                    <th>Voertuigcode</th>
                                    <th>Dagen</th>
                                    <th>Km/dag</th>
                                    <th>kWh/dag</th>
                                    <th>Uren op locatie</th>
                                    <th>Benodigd kW</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in SelectedDetail.Vehicles.Take(20))
                                {
                                    <tr>
                                        <td><strong>@row.Kentekens</strong></td>
                                        <td>@row.Wagencode</td>
                                        <td>@row.Days</td>
                                        <td>@row.AvgDayKm.ToString("N0")</td>
                                        <td>@row.AvgKwhPerDay.ToString("N0")</td>
                                        <td>@row.AvgStandingHours.ToString("N1")</td>
                                        <td>@row.RequiredKw.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>
        }

        <section class="content-grid">
            <div class="table-panel">
                <div class="panel-heading">
                    <h3>Top stoplocaties</h3>
                    <span>@(Dashboard?.TopStops.Length ?? 0) locaties</span>
                </div>
                <div class="table-scroll">
                    <table>
                        <thead>
                            <tr>
                                <th>Locatie</th>
                                <th>Voertuigen</th>
                                <th>Stops</th>
                                <th>Ritten</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Dashboard?.TopStops.Take(12) ?? [])
                            {
                                <tr>
                                    <td>
                                        <strong>@(string.IsNullOrWhiteSpace(row.Name) ? row.Address : row.Name)</strong>
                                        <span>@row.Lat.ToString("0.000"), @row.Lon.ToString("0.000")</span>
                                    </td>
                                    <td>@row.Wagens</td>
                                    <td>@row.Stops</td>
                                    <td>@row.Trips</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="table-panel">
                <div class="panel-heading">
                    <h3>Wegvlakken</h3>
                    <span>@RoadStatusLabel(Dashboard?.RoadStatus)</span>
                </div>
                <div class="table-scroll">
                    <table>
                        <thead>
                            <tr>
                                <th>Segment</th>
                                <th>Rijrichting</th>
                                <th>Lengte</th>
                                <th>Voertuigen</th>
                                <th>Passages</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Dashboard?.TopRoadSegments.Take(12) ?? [])
                            {
                                <tr>
                                    <td><span>@row.Lat1.ToString("0.000"), @row.Lon1.ToString("0.000")</span></td>
                                    <td>@row.Direction</td>
                                    <td>@row.LengthKm.ToString("N1") km</td>
                                    <td>@row.UniqueWagens</td>
                                    <td>@row.Passes</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <section class="simulation-panel">
            <div class="panel-heading">
                <h3>Laadstrategie</h3>
                <button @onclick="RunSimulationAsync" disabled="@IsBusy">Bereken laadniveau</button>
            </div>
            <div class="metric-row compact">
                <div class="metric"><span>Laadmomenten</span><strong>@FormatNumber(Simulation?.ChargeEvents)</strong></div>
                <div class="metric"><span>Ritten met laden</span><strong>@FormatNumber(Simulation?.TripsWithChargeEvent)</strong></div>
                <div class="metric"><span>kWh</span><strong>@FormatNumber(Simulation?.TotalKwh)</strong></div>
                <div class="metric"><span>Laaduren</span><strong>@FormatNumber(Simulation?.TotalChargeHours)</strong></div>
            </div>
        </section>
    </main>
</div>

@if (DemandPopup is not null)
{
    <div class="demand-modal-backdrop" role="presentation" @onclick="CloseDemandPopup">
        <section class="demand-modal" role="dialog" aria-modal="true" aria-labelledby="demand-modal-title" @onclick:stopPropagation>
            <div class="demand-modal__heading">
                <div>
                    <h3 id="demand-modal-title">@DemandPopup.Title</h3>
                    <span>@DemandPopup.Subtitle</span>
                </div>
                <button type="button" class="icon-button" aria-label="Sluiten" title="Sluiten" @onclick="CloseDemandPopup">&times;</button>
            </div>
            @if (DemandPopup.Rows.Length == 0)
            {
                <p class="demand-modal__empty">Geen voertuigen aanwezig in dit uurblok.</p>
            }
            else
            {
                <div class="demand-modal__table">
                    <table>
                        <thead>
                            <tr>
                                <th>Voertuig</th>
                                <th>Kenteken</th>
                                <th>Klasse</th>
                                <th>Venster</th>
                                <th>Stilstand</th>
                                <th>kWh</th>
                                <th>Vermogen</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var vehicle in DemandPopup.Rows)
                            {
                                <tr>
                                    <td><strong>@DisplayValue(vehicle.Wagencode)</strong></td>
                                    <td>@DisplayValue(vehicle.Kenteken)</td>
                                    <td>@DisplayValue(vehicle.VehicleClass)</td>
                                    <td>@DisplayValue(vehicle.Window)</td>
                                    <td>@FormatStandingDuration(vehicle.StandingHours)</td>
                                    <td>@vehicle.DemandKwh.ToString("N0")</td>
                                    <td><strong>@FormatPower(vehicle.RequiredKw)</strong></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
}

@code {
    private MetadataResponse? Metadata { get; set; }
    private SummaryResponse? Summary { get; set; }
    private DashboardResponse? Dashboard { get; set; }
    private SimulationResponse? Simulation { get; set; }
    private SelectionDetailResponse? SelectedDetail { get; set; }
    private PowerProfileResponse? PowerProfiles { get; set; }
    private PowerLocationProfileResponse? SelectedPowerProfile { get; set; }
    private PowerDiagnosticsResponse? PowerDiagnostics { get; set; }
    private DatasetUploadResult? UploadResult { get; set; }
    private DotNetObjectReference<Home>? MapCallbacks { get; set; }
    private bool IsBusy { get; set; }
    private bool IsUploading { get; set; }
    private bool MapReady { get; set; }
    private bool LegendCollapsed { get; set; }
    private string? SelectedDepotId { get; set; }
    private RoadSelection? SelectedRoad { get; set; }
    private StopLocationDetailRequest? SelectedStopLocation { get; set; }
    private int? SelectedDemandDay { get; set; }
    private int? SelectedDemandHour { get; set; }
    private VehicleDemandPopup? DemandPopup { get; set; }

    private string TransportMode { get; set; } = "Alles";
    private string DateFromText { get; set; } = "";
    private string DateToText { get; set; } = "";
    private string VervoerdersText { get; set; } = "";
    private string WagencodesText { get; set; } = "";
    private double MinDwellMin { get; set; }
    private int RoadThreshold { get; set; } = 100;
    private int RoadTopPercent { get; set; } = 1;
    private string ZeZoneMode { get; set; } = "all";
    private bool ShowStopHeat { get; set; } = true;
    private bool ShowMarkers { get; set; } = true;
    private bool ShowRoads { get; set; }
    private bool ShowRoadHeat { get; set; }
    private bool ShowOvernight { get; set; } = true;
    private bool ShowStandplaatsen { get; set; }
    private bool ShowChargers { get; set; } = true;
    private int MinDepotVehicles { get; set; } = 5;
    private double ScenarioKwhPerKm { get; set; } = 1.2;
    private double ScenarioCapacityKwh { get; set; } = 590;
    private bool ScenarioMcsEnabled { get; set; }
    private double ScenarioTargetSocPct { get; set; } = 80;
    private double ScenarioKwPerPlug { get; set; } = 350;
    private int ScenarioPlugs { get; set; } = 4;
    private double ScenarioSiteLimitMw { get; set; } = 1.4;
    private double ChargerMinPowerKw { get; set; } = 150;
    private bool ChargerOnlyDedicated { get; set; }
    private bool ChargerAccessPublic { get; set; } = true;
    private bool ChargerAccessSemiPublic { get; set; } = true;
    private bool ChargerAccessPrivate { get; set; }
    private double MaxVehicleKw => ScenarioMcsEnabled ? 1_500 : 400;

    protected override async Task OnInitializedAsync()
    {
        Metadata = await Analysis.GetMetadataAsync();
        if (Metadata.MinDate is not null)
        {
            DateFromText = Metadata.MinDate.Value.ToString("yyyy-MM-dd");
        }

        if (Metadata.MaxDate is not null)
        {
            DateToText = Metadata.MaxDate.Value.ToString("yyyy-MM-dd");
        }

        await LoadDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            MapCallbacks = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("routePlannerMap.init", "route-map", MapCallbacks);
            MapReady = true;
            await RefreshMapAsync();
        }
    }

    private async Task ApplyFiltersAsync()
    {
        await LoadDataAsync();
        await RefreshMapAsync();
        await RefreshSelectedDetailAsync();
    }

    private async Task UploadDatasetAsync(InputFileChangeEventArgs e)
    {
        IsUploading = true;
        IsBusy = true;
        UploadResult = null;
        SelectedDetail = null;
        SelectedDepotId = null;
        SelectedRoad = null;
        SelectedStopLocation = null;
        SelectedDemandDay = null;
        SelectedDemandHour = null;
        DemandPopup = null;
        await ClearSelectionHeatAsync();

        try
        {
            UploadResult = await Analysis.ReplaceDatasetAsync(e.GetMultipleFiles(24));
            Metadata = await Analysis.GetMetadataAsync();
            DateFromText = Metadata.MinDate?.ToString("yyyy-MM-dd") ?? "";
            DateToText = Metadata.MaxDate?.ToString("yyyy-MM-dd") ?? "";
            await LoadDataAsync();
            await RefreshMapAsync();
        }
        finally
        {
            IsUploading = false;
            IsBusy = false;
        }
    }

    private async Task LoadDataAsync()
    {
        IsBusy = true;
        try
        {
            var filter = BuildFilter();
            Summary = await Analysis.GetSummaryAsync(filter);
            Dashboard = await Analysis.GetDashboardAsync(filter);
            await LoadPowerProfilesAsync();
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task LoadPowerProfilesAsync()
    {
        var filter = BuildFilter();
        PowerProfiles = await Analysis.GetPowerProfilesAsync(new PowerProfileRequest
        {
            DateFrom = filter.DateFrom,
            DateTo = filter.DateTo,
            VervoerderTypes = filter.VervoerderTypes,
            Vervoerders = filter.Vervoerders,
            Wagencodes = filter.Wagencodes,
            MinDwellMin = filter.MinDwellMin,
            ZeZoneMode = filter.ZeZoneMode,
            TopLocations = 5,
            ScenarioYears = [2027, 2030],
            ScenarioMode = "linear",
            CapacityKwh = ScenarioCapacityKwh,
            MaxVehicleKw = MaxVehicleKw,
            VehicleClasses = PowerVehicleClasses()
        });
        PowerDiagnostics = await Analysis.GetPowerDiagnosticsAsync(filter);
    }

    private async Task RefreshPowerProfilesAsync()
    {
        if (IsBusy)
        {
            return;
        }

        IsBusy = true;
        SelectedPowerProfile = null;
        DemandPopup = null;
        try
        {
            await LoadPowerProfilesAsync();
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task SelectPowerLocationAsync(string locationId)
    {
        var filter = BuildFilter();
        try
        {
            SelectedPowerProfile = await Analysis.GetPowerLocationProfileAsync(new PowerLocationProfileRequest
            {
                DateFrom = filter.DateFrom,
                DateTo = filter.DateTo,
                VervoerderTypes = filter.VervoerderTypes,
                Vervoerders = filter.Vervoerders,
                Wagencodes = filter.Wagencodes,
                MinDwellMin = filter.MinDwellMin,
                ZeZoneMode = filter.ZeZoneMode,
                LocationId = locationId,
                ScenarioYears = [2027, 2030],
                ScenarioMode = "linear",
                CapacityKwh = ScenarioCapacityKwh,
                MaxVehicleKw = MaxVehicleKw,
                VehicleClasses = PowerVehicleClasses()
            });
        }
        catch (Exception ex)
        {
            // Surface error to caller via popup; don't propagate to circuit handler.
            SelectedPowerProfile = new PowerLocationProfileResponse(
                "error",
                $"{ex.GetType().Name}: {ex.Message}",
                null,
                [],
                [],
                false);
            throw;
        }
    }

    private async Task RunSimulationAsync()
    {
        IsBusy = true;
        try
        {
            var filter = BuildFilter();
            Simulation = await Analysis.GetSimulationAsync(new SimulationRequest
            {
                DateFrom = filter.DateFrom,
                DateTo = filter.DateTo,
                VervoerderTypes = filter.VervoerderTypes,
                Vervoerders = filter.Vervoerders,
                Wagencodes = filter.Wagencodes,
                MinDwellMin = filter.MinDwellMin,
                RoadThreshold = filter.RoadThreshold,
                RoadTopPercent = filter.RoadTopPercent,
                MarkerTopN = filter.MarkerTopN,
                ZeZoneMode = filter.ZeZoneMode,
            });
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task RefreshMapAsync()
    {
        if (!MapReady)
        {
            return;
        }

        await JS.InvokeVoidAsync("routePlannerMap.update", BuildFilter(), BuildChargerFilter(), BuildOvernightFilter(), new
        {
            showStopHeat = ShowStopHeat,
            showMarkers = ShowMarkers,
            showRoads = ShowRoads,
            showRoadHeat = ShowRoadHeat,
            showOvernight = ShowOvernight,
            showStandplaatsen = ShowStandplaatsen,
            showChargers = ShowChargers
        });
    }

    private AnalysisFilter BuildFilter()
    {
        return new AnalysisFilter
        {
            DateFrom = ParseDate(DateFromText),
            DateTo = ParseDate(DateToText),
            VervoerderTypes = TransportMode switch
            {
                "Eigen" => ["eigen"],
                "Charter" => ["charter"],
                _ => []
            },
            Vervoerders = SplitList(VervoerdersText),
            Wagencodes = SplitList(WagencodesText),
            MinDwellMin = MinDwellMin,
            RoadThreshold = RoadThreshold,
            RoadTopPercent = RoadTopPercent,
            MarkerTopN = 250,
            ZeZoneMode = ZeZoneMode,
        };
    }

    private ChargerFilter BuildChargerFilter()
    {
        var access = new List<string>();
        if (ChargerAccessPublic)
        {
            access.Add("Publiek");
        }

        if (ChargerAccessSemiPublic)
        {
            access.Add("Semi-publiek");
        }

        if (ChargerAccessPrivate)
        {
            access.Add("Privaat");
        }

        return new ChargerFilter
        {
            MinPowerKw = ChargerMinPowerKw,
            OnlyDedicated = ChargerOnlyDedicated,
            Access = access.ToArray(),
        };
    }

    private OvernightLocationsRequest BuildOvernightFilter()
    {
        var filter = BuildFilter();
        return new OvernightLocationsRequest
        {
            DateFrom = filter.DateFrom,
            DateTo = filter.DateTo,
            VervoerderTypes = filter.VervoerderTypes,
            Vervoerders = filter.Vervoerders,
            Wagencodes = filter.Wagencodes,
            RoadThreshold = filter.RoadThreshold,
            RoadTopPercent = filter.RoadTopPercent,
            MarkerTopN = 100,
            ZeZoneMode = filter.ZeZoneMode,
            MinVehicles = MinDepotVehicles,
            Scenario = BuildScenario()
        };
    }

    private ChargingScenario BuildScenario()
    {
        return new ChargingScenario
        {
            KwhPerKm = ScenarioKwhPerKm,
            CapacityKwh = ScenarioCapacityKwh,
            MinSocPct = 15,
            TargetSocPct = ScenarioTargetSocPct,
            KwPerPlug = ScenarioKwPerPlug,
            Plugs = ScenarioPlugs,
            SiteLimitMw = ScenarioSiteLimitMw
        };
    }

    [JSInvokable]
    public async Task SelectDepotAsync(string depotId)
    {
        SelectedDepotId = depotId;
        SelectedRoad = null;
        SelectedStopLocation = null;
        SelectedDemandDay = null;
        SelectedDemandHour = null;
        DemandPopup = null;
        await RefreshSelectedDetailAsync();
        StateHasChanged();
    }

    [JSInvokable]
    public async Task SelectStopLocationAsync(double lat, double lon, string label)
    {
        SelectedStopLocation = new StopLocationDetailRequest
        {
            Lat = lat,
            Lon = lon,
            Label = label,
            RadiusKm = 0.5
        };
        SelectedDepotId = null;
        SelectedRoad = null;
        SelectedDemandDay = null;
        SelectedDemandHour = null;
        DemandPopup = null;
        await RefreshSelectedDetailAsync();
        StateHasChanged();
    }

    [JSInvokable]
    public async Task SelectRoadAsync(double lat1, double lon1, double lat2, double lon2, double radiusKm = 3)
    {
        SelectedRoad = new RoadSelection(lat1, lon1, lat2, lon2, radiusKm);
        SelectedDepotId = null;
        SelectedStopLocation = null;
        SelectedDemandDay = null;
        SelectedDemandHour = null;
        DemandPopup = null;
        await RefreshSelectedDetailAsync();
        StateHasChanged();
    }

    private async Task RefreshSelectedDetailAsync()
    {
        if (SelectedDepotId is null && SelectedRoad is null && SelectedStopLocation is null)
        {
            await ClearSelectionHeatAsync();
            return;
        }

        IsBusy = true;
        try
        {
            var filter = BuildFilter();
            if (SelectedDepotId is not null)
            {
                SelectedDetail = await Analysis.GetOvernightLocationDetailAsync(new OvernightLocationDetailRequest
                {
                    DateFrom = filter.DateFrom,
                    DateTo = filter.DateTo,
                    VervoerderTypes = filter.VervoerderTypes,
                    Vervoerders = filter.Vervoerders,
                    Wagencodes = filter.Wagencodes,
                    RoadThreshold = filter.RoadThreshold,
                    RoadTopPercent = filter.RoadTopPercent,
                    MarkerTopN = filter.MarkerTopN,
                    ZeZoneMode = filter.ZeZoneMode,
                    DepotId = SelectedDepotId,
                    Scenario = BuildScenario()
                });
                var peakDemand = SelectedDetail.Charging.WeeklyProfile
                    .OrderByDescending(x => x.RequiredKw)
                    .ThenByDescending(x => x.Vehicles)
                    .FirstOrDefault(x => x.RequiredKw > 0 || x.Vehicles > 0)
                    ?? SelectedDetail.Charging.WeeklyProfile.FirstOrDefault();
                SelectedDemandDay ??= peakDemand?.DayIndex;
                SelectedDemandHour ??= peakDemand?.Hour;
            }
            else if (SelectedStopLocation is not null)
            {
                SelectedDetail = await Analysis.GetStopLocationDetailAsync(SelectedStopLocation with
                {
                    DateFrom = filter.DateFrom,
                    DateTo = filter.DateTo,
                    VervoerderTypes = filter.VervoerderTypes,
                    Vervoerders = filter.Vervoerders,
                    Wagencodes = filter.Wagencodes,
                    RoadThreshold = filter.RoadThreshold,
                    RoadTopPercent = filter.RoadTopPercent,
                    MarkerTopN = filter.MarkerTopN,
                    ZeZoneMode = filter.ZeZoneMode,
                    Scenario = BuildScenario()
                });
            }
            else if (SelectedRoad is not null)
            {
                SelectedDetail = await Analysis.GetRoadSelectionAsync(new RoadSelectionRequest
                {
                    DateFrom = filter.DateFrom,
                    DateTo = filter.DateTo,
                    VervoerderTypes = filter.VervoerderTypes,
                    Vervoerders = filter.Vervoerders,
                    Wagencodes = filter.Wagencodes,
                    RoadThreshold = filter.RoadThreshold,
                    RoadTopPercent = filter.RoadTopPercent,
                    MarkerTopN = filter.MarkerTopN,
                    ZeZoneMode = filter.ZeZoneMode,
                    Road = SelectedRoad,
                    Scenario = BuildScenario()
                });
            }

            if (MapReady && SelectedDetail is not null && SelectedDetail.SelectionType == "stop")
            {
                await JS.InvokeVoidAsync("routePlannerMap.updateSelectionHeat", SelectedDetail.HeatPoints);
            }
            else
            {
                await ClearSelectionHeatAsync();
            }
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task SetTransportModeAsync(string mode)
    {
        if (TransportMode == mode || IsBusy)
        {
            return;
        }

        TransportMode = mode;
        SelectedDetail = null;
        SelectedPowerProfile = null;
        DemandPopup = null;
        await ApplyFiltersAsync();
    }

    private string ModeClass(string mode) => TransportMode == mode ? "active" : "";

    private string PowerTransportLabel => TransportMode switch
    {
        "Eigen" => "Alleen eigen vervoer",
        "Charter" => "Alleen chartervervoer",
        _ => "Alle voertuigen"
    };

    private string[] PowerVehicleClasses()
    {
        return TransportMode switch
        {
            "Eigen" => ["own"],
            "Charter" => ["charter"],
            _ => []
        };
    }

    private static string SelectionTypeLabel(string selectionType)
    {
        return selectionType switch
        {
            "road" => "Wegvlakselectie",
            "stop" => "Vertrekkende dagritten vanaf stoplocatie",
            _ => "Vaste stilstandlocatie"
        };
    }

    private async Task ClearSelectionHeatAsync()
    {
        if (MapReady)
        {
            await JS.InvokeVoidAsync("routePlannerMap.clearSelectionHeat");
        }
    }

    private void SelectDemandBlock(int dayIndex, int hour)
    {
        SelectedDemandDay = dayIndex;
        SelectedDemandHour = hour;
    }

    private void OpenDemandPopup(WeeklyDemandCell cell)
    {
        SelectDemandBlock(cell.DayIndex, cell.Hour);
        DemandPopup = new VehicleDemandPopup(
            cell.Label,
            $"{cell.Vehicles:N0} voertuigen · {FormatPower(cell.RequiredKw)} gevraagd",
            cell.VehicleDemands
                .Select(vehicle => new VehicleDemandPopupRow(
                    vehicle.Wagencode,
                    vehicle.Kenteken,
                    "",
                    vehicle.DemandKwh,
                    vehicle.RequiredKw,
                    vehicle.StandingHours,
                    vehicle.Window))
                .ToArray());
    }

    private async Task OpenPowerDemandPopupAsync(PowerLocationProfile profile, PowerHourlyCell cell)
    {
        // Open popup immediately with what we already know so user gets feedback,
        // even if backend is slow or hangs.
        var initialTitle = cell.Date is null ? cell.Label : $"{cell.Date.Value:dd-MM-yyyy} {cell.Label}";
        DemandPopup = new VehicleDemandPopup(
            $"{profile.Name} · {initialTitle}",
            $"{cell.Vehicles:N0} voertuigen · {FormatPower(cell.RequiredKw)} gevraagd · laden…",
            []);
        IsBusy = true;
        StateHasChanged();

        try
        {
            await SelectPowerLocationAsync(profile.LocationId);
            var detailCell = SelectedPowerProfile?.Profile?.HourlyProfile.FirstOrDefault(x => x.Hour == cell.Hour) ?? cell;
            var titleDate = detailCell.Date is null ? detailCell.Label : $"{detailCell.Date.Value:dd-MM-yyyy} {detailCell.Label}";
            var demandKwh = detailCell.VehicleDemands.Sum(x => x.DemandKwh);
            DemandPopup = new VehicleDemandPopup(
                $"{profile.Name} · {titleDate}",
                $"{detailCell.Vehicles:N0} voertuigen · {FormatPower(detailCell.RequiredKw)} gevraagd · {demandKwh:N0} kWh",
                detailCell.VehicleDemands
                    .Select(vehicle => new VehicleDemandPopupRow(
                        vehicle.Wagencode,
                        vehicle.Kenteken,
                        vehicle.VehicleClass,
                        vehicle.DemandKwh,
                        vehicle.RequiredKw,
                        vehicle.StandingHours,
                        vehicle.Window))
                    .ToArray());
        }
        catch (Exception ex)
        {
            DemandPopup = new VehicleDemandPopup(
                $"{profile.Name} · {initialTitle}",
                $"Kon detail niet laden: {ex.GetType().Name}: {ex.Message}",
                []);
        }
        finally
        {
            IsBusy = false;
            StateHasChanged();
        }
    }

    private void CloseDemandPopup()
    {
        DemandPopup = null;
    }

    private WeeklyDemandCell? SelectedWeeklyDemandCell()
    {
        if (SelectedDetail is null || SelectedDetail.Charging.WeeklyProfile.Length == 0)
        {
            return null;
        }

        var peak = SelectedDetail.Charging.WeeklyProfile
            .OrderByDescending(x => x.RequiredKw)
            .ThenByDescending(x => x.Vehicles)
            .FirstOrDefault(x => x.RequiredKw > 0 || x.Vehicles > 0)
            ?? SelectedDetail.Charging.WeeklyProfile.FirstOrDefault();
        var day = SelectedDemandDay ?? peak?.DayIndex;
        var hour = SelectedDemandHour ?? peak?.Hour;

        return day is null || hour is null
            ? null
            : SelectedDetail.Charging.WeeklyProfile.FirstOrDefault(x => x.DayIndex == day.Value && x.Hour == hour.Value);
    }

    private string WeekCellClass(WeeklyDemandCell cell)
    {
        var classes = cell.RequiredKw <= 0 && cell.Vehicles <= 0 ? "week-cell is-empty" : "week-cell";
        return SelectedDemandDay == cell.DayIndex && SelectedDemandHour == cell.Hour ? $"{classes} active" : classes;
    }

    private string WeekCellStyle(WeeklyDemandCell cell)
    {
        var max = SelectedDetail?.Charging.WeeklyProfile.Max(x => x.RequiredKw) ?? 0;
        var intensity = max <= 0 ? 0 : Math.Clamp(cell.RequiredKw / max, 0, 1);
        var alpha = cell.RequiredKw <= 0 && cell.Vehicles <= 0 ? 0 : 0.12 + 0.78 * intensity;
        return $"--hour-alpha:{alpha.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}";
    }

    private static string PowerCellStyle(double requiredKw, IReadOnlyCollection<PowerLocationProfile> profiles)
    {
        var max = profiles.SelectMany(x => x.HourlyProfile).Select(x => x.RequiredKw).DefaultIfEmpty(0).Max();
        var intensity = max <= 0 ? 0 : Math.Clamp(requiredKw / max, 0, 1);
        var alpha = requiredKw <= 0 ? 0 : 0.14 + 0.76 * intensity;
        return $"--power-alpha:{alpha.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}";
    }

    private static string PowerBarStyle(double requiredKw, IReadOnlyCollection<PowerHourlyCell> hours)
    {
        var max = hours.Select(x => x.RequiredKw).DefaultIfEmpty(0).Max();
        var height = max <= 0 ? 2 : Math.Max(4, Math.Round(100 * requiredKw / max, 1));
        return $"--bar-height:{height.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)}%";
    }

    private static IEnumerable<PowerDailyMetric> TopPowerDays(IEnumerable<PowerDailyMetric> days)
    {
        return days
            .OrderByDescending(x => x.PeakKw)
            .ThenByDescending(x => x.UniqueVehicles)
            .ThenBy(x => x.Date)
            .Take(10);
    }

    private static string ShortDayLabel(string dayLabel)
    {
        return dayLabel switch
        {
            "Maandag" => "Ma",
            "Dinsdag" => "Di",
            "Woensdag" => "Wo",
            "Donderdag" => "Do",
            "Vrijdag" => "Vr",
            "Zaterdag" => "Za",
            "Zondag" => "Zo",
            _ => dayLabel
        };
    }

    private static string JoinValues(IReadOnlyCollection<string> values, string empty)
    {
        if (values.Count == 0)
        {
            return empty;
        }

        const int maxVisible = 12;
        var visible = values.Take(maxVisible).ToArray();
        return values.Count <= maxVisible
            ? string.Join(", ", visible)
            : string.Join(", ", visible) + $" +{values.Count - maxVisible}";
    }

    private static string DisplayValue(string value)
    {
        return string.IsNullOrWhiteSpace(value) ? "-" : value;
    }

    private int EmptyWeekCellCount()
    {
        return SelectedDetail?.Charging.WeeklyProfile.Count(x => x.RequiredKw <= 0 && x.Vehicles <= 0) ?? 0;
    }

    private static string RoadStatusLabel(string? status)
    {
        return status switch
        {
            "ok" => "Beschikbaar",
            "skipped" => "Verborgen",
            "cache_missing" => "Niet beschikbaar",
            null or "" => "Niet beschikbaar",
            _ => "Niet beschikbaar"
        };
    }

    private static DateOnly? ParseDate(string value)
    {
        return DateOnly.TryParse(value, out var date) ? date : null;
    }

    private static string[] SplitList(string value)
    {
        return value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    }

    private static string HistogramWidth(long trips, IReadOnlyCollection<DistanceBucket> buckets)
    {
        var max = buckets.Count == 0 ? 0 : buckets.Max(x => x.Trips);
        var width = max <= 0 ? 0 : Math.Max(4, Math.Round(100.0 * trips / max, 1));
        return width.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture) + "%";
    }

    private static string FormatNumber(double? value) => value is null ? "-" : value.Value.ToString("N0");
    private static string FormatNumber(long? value) => value is null ? "-" : value.Value.ToString("N0");

    private static string FormatPower(double kw)
    {
        if (kw <= 0)
        {
            return "0 kW";
        }

        if (kw < 1000)
        {
            return $"{kw:N0} kW";
        }

        var mw = kw / 1000.0;
        return mw >= 100 ? $"{mw:N0} MW" : $"{mw:N1} MW";
    }

    private static string FormatStandingDuration(double hours)
    {
        if (hours <= 0)
        {
            return "0 min";
        }

        var minutes = hours * 60.0;
        if (minutes < 10)
        {
            return $"{minutes:N1} min";
        }

        if (minutes < 120)
        {
            return $"{minutes:N0} min";
        }

        return $"{hours:N1} uur";
    }

    private sealed record VehicleDemandPopup(
        string Title,
        string Subtitle,
        VehicleDemandPopupRow[] Rows);

    private sealed record VehicleDemandPopupRow(
        string Wagencode,
        string Kenteken,
        string VehicleClass,
        double DemandKwh,
        double RequiredKw,
        double StandingHours,
        string Window);

    public void Dispose()
    {
        MapCallbacks?.Dispose();
    }
}
