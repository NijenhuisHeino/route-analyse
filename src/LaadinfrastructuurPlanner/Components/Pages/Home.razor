    private void ShowDemandPopup(VehicleDemandPopup popup)
    {
        DemandPopup = popup;
    }

    private async Task OpenPowerDemandPopupAsync((PowerLocationProfile Profile, PowerHourlyCell Cell) args)
    {
        await SelectPowerLocationAsync(args.Profile.LocationId);
        var detailCell = SelectedPowerProfile?.Profile?.HourlyProfile.FirstOrDefault(x => x.Hour == args.Cell.Hour) ?? args.Cell;
        var titleDate = detailCell.Date is null ? detailCell.Label : $"{detailCell.Date.Value:dd-MM-yyyy} {detailCell.Label}";
        var demandKwh = detailCell.VehicleDemands.Sum(x => x.DemandKwh);
        DemandPopup = new VehicleDemandPopup(
            $"{args.Profile.Name} · {titleDate}",
            $"{detailCell.Vehicles:N0} voertuigen · {UiFormat.FormatPower(detailCell.RequiredKw)} gevraagd · {demandKwh:N0} kWh",
            detailCell.VehicleDemands
                .Select(vehicle => new VehicleDemandPopupRow(
                    vehicle.Wagencode,
                    vehicle.Kenteken,
                    vehicle.VehicleClass,
                    vehicle.DemandKwh,
                    vehicle.RequiredKw,
                    vehicle.StandingHours,
                    vehicle.Window))
                .ToArray());
    }

    private void CloseDemandPopup()
    {
        DemandPopup = null;
    }

    private static DateOnly? ParseDate(string value)
    {
        return DateOnly.TryParse(value, out var date) ? date : null;
    }

    private static string[] SplitList(string value)
    {
        return value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
    }

    public void Dispose()
    {
        MapCallbacks?.Dispose();
    }
}
