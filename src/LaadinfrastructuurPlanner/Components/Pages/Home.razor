@page "/"
@implements IDisposable
@inject RouteAnalysisService Analysis
@inject IJSRuntime JS

<PageTitle>Laadinfrastructuur Planner</PageTitle>

<div class="planner-shell">
    <aside class="planner-sidebar">
        <div class="brand-block">
            <div class="brand-mark">LI</div>
            <div>
                <h1>Laadinfrastructuur Planner</h1>
                <p>Depot- en corridoranalyse</p>
            </div>
        </div>

        <section class="filter-group">
            <label>Vervoersvorm</label>
            <div class="segmented">
                <button class="@ModeClass("Alles")" @onclick='() => SetTransportModeAsync("Alles")' disabled="@IsBusy">Alles</button>
                <button class="@ModeClass("Eigen")" @onclick='() => SetTransportModeAsync("Eigen")' disabled="@IsBusy">Eigen</button>
                <button class="@ModeClass("Charter")" @onclick='() => SetTransportModeAsync("Charter")' disabled="@IsBusy">Charter</button>
            </div>
        </section>

        <section class="filter-grid">
            <label>
                Datum vanaf
                <input type="date" value="@DateFromText" @onchange="e => DateFromText = e.Value?.ToString() ?? string.Empty" />
            </label>
            <label>
                Datum tot
                <input type="date" value="@DateToText" @onchange="e => DateToText = e.Value?.ToString() ?? string.Empty" />
            </label>
            <label>
                Vervoerders
                <input placeholder="namen scheiden met komma's" @bind="VervoerdersText" />
            </label>
            <label>
                Voertuigen of kentekens
                <input placeholder="wagen-codes of kentekens" @bind="WagencodesText" />
            </label>
            <label>
                Min. stopduur (min)
                <input type="number" min="0" max="180" step="5" @bind="MinDwellMin" />
            </label>
            <label>
                ZE-zones
                <select @bind="ZeZoneMode">
                    <option value="all">Alle ritten en stops</option>
                    <option value="in">Alleen in ZE-zone</option>
                    <option value="out">Alleen buiten ZE-zone</option>
                </select>
            </label>
            <label>
                Min. passages per wegvlak
                <input type="number" min="1" max="1000000" step="50" @bind="RoadThreshold" />
                <input class="range-control" type="range" min="1" max="5000" step="25" @bind="RoadThreshold" @bind:event="oninput" />
            </label>
            <label>
                Zichtbare wegdata
                <input type="number" min="1" max="25" step="1" @bind="RoadTopPercent" />
                <input class="range-control" type="range" min="1" max="25" step="1" @bind="RoadTopPercent" @bind:event="oninput" />
                <span class="range-value">@RoadTopPercent% van beschikbare wegpunten en wegvlakken</span>
            </label>
        </section>

        <section class="filter-group">
            <label>Kaartlagen</label>
            @foreach (var layer in MapLayers)
            {
                <div class="layer-toggle-item">
                    <div class="layer-toggle-row">
                        <label class="toggle layer-toggle-label" for="@($"layer-{layer.Id}")">
                            <input id="@($"layer-{layer.Id}")" type="checkbox" checked="@layer.Get()" @onchange="async e => { layer.Set((bool)e.Value!); await RefreshMapAsync(); }" /> @layer.Label
                        </label>
                        <button type="button"
                                class="@LayerInfoButtonClass(layer.Id)"
                                aria-label="@($"Uitleg over {layer.Label}")"
                                aria-expanded="@LayerInfoExpanded(layer.Id)"
                                aria-controls="@($"layer-info-{layer.Id}")"
                                @onclick="() => ToggleLayerInfo(layer.Id)">i</button>
                    </div>
                    @if (OpenLayerInfoId == layer.Id)
                    {
                        <p id="@($"layer-info-{layer.Id}")" class="layer-info-panel @(layer.Disclaimer ? "disclaimer" : "")">@layer.Info</p>
                    }
                </div>
            }
        </section>

        <section class="filter-grid demand-controls">
            <label class="filter-group-title">Voertuig</label>
            <label>
                kWh/km
                <input type="number" min="0.5" max="3.5" step="0.1" @bind="ScenarioKwhPerKm" @bind:after="RefreshVehicleScenarioAsync" />
            </label>
            <label>
                Batterijcapaciteit (kWh)
                <input type="number" min="100" max="1500" step="10" @bind="ScenarioCapacityKwh" @bind:after="RefreshVehicleScenarioAsync" />
            </label>
            <label class="toggle mcs-toggle"><input type="checkbox" @bind="ScenarioMcsEnabled" @bind:after="RefreshPowerProfilesAsync" /> MCS laden toestaan</label>
            <span class="range-value">Max. afname per truck: @MaxVehicleKw.ToString("N0") kW</span>
            <label>
                Doel laadniveau (%)
                <input type="number" min="20" max="100" step="5" @bind="ScenarioTargetSocPct" @bind:after="RefreshVehicleScenarioAsync" />
            </label>
            <label>
                Rijtijd vanaf (uur)
                <input type="number" min="0.5" max="12" step="0.25" @bind="BreakWindowStartHours" @bind:after="RefreshMapAsync" />
            </label>
            <label>
                Rijtijd tot (uur)
                <input type="number" min="0.75" max="14" step="0.25" @bind="BreakWindowEndHours" @bind:after="RefreshMapAsync" />
            </label>
            <label>
                Pauzeduur (uur)
                <input type="number" min="0.25" max="3" step="0.25" @bind="BreakDurationHours" @bind:after="RefreshMapAsync" />
            </label>
            <label>
                Min. pauzepassages
                <input type="number" min="1" max="500" step="1" @bind="BreakDemandMinPassages" @bind:after="RefreshMapAsync" />
            </label>
            <label>
                Top pauzelaadvraag (%)
                <input type="number" min="0" max="100" step="1" @bind="BreakDemandTopPercent" @bind:after="RefreshMapAsync" />
                <input class="range-control" type="range" min="0" max="100" step="1" @bind="BreakDemandTopPercent" @bind:event="oninput" @bind:after="RefreshMapAsync" />
                <span class="range-value">Top @BreakDemandTopPercent% op aantal pauzepassages</span>
            </label>
            <label>
                Shift-reset gap (uur)
                <input type="number" min="0.5" max="12" step="0.25" @bind="ShiftResetGapHours" @bind:after="RefreshMapAsync" />
            </label>
            <label class="filter-group-title">Depotselectie</label>
            <label>
                Min. voertuigen per depot
                <input type="number" min="1" max="100" step="1" @bind="MinDepotVehicles" />
            </label>
            <label class="filter-group-title">Vereist een publieke laadlocatie</label>
            <label>
                Vermogen per stekker (kW)
                <input type="number" min="0" max="2000" step="50" @bind="ChargerMinPowerKw" @bind:after="RefreshMapAsync" />
            </label>
            <label>
                Min. aantal stekkers
                <input type="number" min="1" max="100" step="1" @bind="ChargerMinConnectors" @bind:after="RefreshMapAsync" />
            </label>
            <label class="toggle"><input type="checkbox" @bind="ChargerOnlyDedicated" @bind:after="RefreshMapAsync" /> Alleen gereserveerd</label>
            <label class="toggle"><input type="checkbox" @bind="ChargerAccessPublic" @bind:after="RefreshMapAsync" /> Publiek</label>
            <label class="toggle"><input type="checkbox" @bind="ChargerAccessSemiPublic" @bind:after="RefreshMapAsync" /> Semi-publiek</label>
            <label class="toggle"><input type="checkbox" @bind="ChargerAccessPrivate" @bind:after="RefreshMapAsync" /> Privaat</label>
        </section>

        <button class="primary-action" @onclick="ApplyFiltersAsync" disabled="@IsBusy">
            @(IsBusy ? "Bijwerken..." : "Analyse bijwerken")
        </button>

        @if (Metadata is not null)
        {
            <div class="cache-status">
                <strong>Gegevens</strong>
                <span>@(Metadata.DataAvailable ? Metadata.DataSource : "Ritgegevens niet beschikbaar")</span>
                <span>@Metadata.StopCount.ToString("N0") stopmomenten</span>
            </div>
        }

        <section class="upload-panel">
            <div>
                <strong>Eigen dataset</strong>
                <span>CSV of parquet met ritregels</span>
            </div>
            <InputFile OnChange="UploadDatasetAsync" multiple accept=".csv,.parquet" />
            <p>CSV gebruikt bij voorkeur kolommen voor voertuig, rit, start/eind, afstand en lat/lon. Zonder lat/lon is een locatiekoppeling nodig.</p>
            @if (IsUploading)
            {
                <span class="upload-status">Dataset verwerken...</span>
            }
            else if (UploadResult is not null)
            {
                <span class="upload-status @(UploadResult.Success ? "ok" : "error")">@UploadResult.Message</span>
            }
        </section>
    </aside>

    <main class="planner-main">
        <header class="planner-header">
            <div>
                <p class="section-label">Route-analyse</p>
                <h2>Laadvraag per depot en druk wegvlak</h2>
            </div>
            <div class="header-status @(Metadata?.DataAvailable == true ? "ok" : "missing")">
                @(Metadata?.DataAvailable == true ? "Gegevens geladen" : "Gegevens ontbreken")
            </div>
        </header>

        @if (Metadata?.DataAvailable != true)
        {
            <section class="empty-state">
                <h3>Geen ritgegevens gevonden</h3>
                <p>Controleer of de ritbestanden en locatiegegevens beschikbaar zijn.</p>
            </section>
        }

        <section class="metric-row">
            <div class="metric"><span>Stopmomenten</span><strong>@UiFormat.FormatNumber(Summary?.Stops)</strong></div>
            <div class="metric"><span>Dagritten</span><strong>@UiFormat.FormatNumber(Summary?.Trips)</strong></div>
            <div class="metric"><span>Voertuigen</span><strong>@UiFormat.FormatNumber(Summary?.Wagens)</strong></div>
            <div class="metric"><span>Totale km</span><strong>@UiFormat.FormatNumber(Summary?.TotalKm)</strong></div>
            <div class="metric"><span>Stopduur (uur)</span><strong>@UiFormat.FormatNumber(Summary?.TotalDwellHours)</strong></div>
        </section>

        <PowerProfilePanel Profiles="PowerProfiles"
                           Diagnostics="PowerDiagnostics"
                           Selected="SelectedPowerProfile"
                           IsBusy="IsBusy"
                           TransportLabel="@PowerTransportLabel"
                           CapacityKwh="ScenarioCapacityKwh"
                           MaxVehicleKw="MaxVehicleKw"
                           OnRefresh="RefreshPowerProfilesAsync"
                           OnSelectLocation="SelectPowerLocationAsync"
                           OnOpenPopup="OpenPowerDemandPopupAsync" />

        <ZeZonesPanel Zones="@(Dashboard?.ZeZones ?? [])"
                      ShowEmptyState="@(Metadata?.ZeZones.Length > 0 && ZeZoneMode == "in")" />

        <section class="map-panel">
            <div class="panel-heading">
                <h3>Kaart</h3>
                <span id="map-status">Klaar</span>
            </div>
            <div class="map-frame">
                <div id="route-map" class="route-map"></div>
                <aside class="map-legend @(LegendCollapsed ? "is-collapsed" : "")" aria-label="Legenda kaartlagen">
                    <div class="legend-heading">
                        <strong>Legenda</strong>
                        @if (!LegendCollapsed)
                        {
                            <span>Actieve lagen</span>
                        }
                        <button type="button"
                                class="legend-toggle"
                                data-legend-toggle="true"
                                title="@(LegendCollapsed ? "Legenda tonen" : "Legenda minimaliseren")"
                                aria-label="@(LegendCollapsed ? "Legenda tonen" : "Legenda minimaliseren")"
                                aria-expanded="@((!LegendCollapsed).ToString().ToLowerInvariant())"
                                @onclick="ToggleLegend"
                                @onclick:stopPropagation="true"
                                @onclick:preventDefault="true">
                            @(LegendCollapsed ? "+" : "-")
                        </button>
                    </div>

                    @if (!LegendCollapsed && ShowStopHeat)
                    {
                        <div class="legend-item heat">
                            <span class="legend-gradient stop-gradient"></span>
                            <div>
                                <strong>Stopdrukte</strong>
                                <span>Blauw naar rood: van beperkte naar zeer hoge stopdrukte.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && ShowMarkers)
                    {
                        <div class="legend-item">
                            <span class="legend-symbol stop-marker"></span>
                            <div>
                                <strong>Toplocaties</strong>
                                <span>Blauwe rondjes met witte rand; groter betekent meer voertuigen.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && ShowChargers)
                    {
                        <div class="legend-item">
                            <span class="legend-symbol charger-marker"></span>
                            <div>
                                <strong>Laadlocaties</strong>
                                <span>Groene rondjes met witte rand; groter betekent hoger vermogen.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && ShowOvernight)
                    {
                        <div class="legend-item">
                            <span class="legend-symbol overnight-ok"></span>
                            <div>
                                <strong>Vaste stilstandlocaties</strong>
                                <span>Stilstandlocaties uit ritdata; klik voor publieke laadvraag per weekuur.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && ShowStandplaatsen)
                    {
                        <div class="legend-item">
                            <span class="legend-symbol standplaats-marker"></span>
                            <div>
                                <strong>Standplaatsen (wagenpark)</strong>
                                <span>Donkerblauwe rondjes met witte rand; groter betekent meer voertuigen op die standplaats. Klik voor voertuigenlijst.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && ShowCharterStandplaatsen)
                    {
                        <div class="legend-item">
                            <span class="legend-symbol charter-standplaats-marker"></span>
                            <div>
                                <strong>Charterstandplaatsen</strong>
                                <span>Paarse rondjes met witte rand; groter betekent meer chartervoertuigen.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && ShowRoads)
                    {
                        <div class="legend-item">
                            <span class="legend-line road-line"></span>
                            <div>
                                <strong>Wegvlakken</strong>
                                <span>Klikbare paarse toplijnen met segment-identiteit. Aantal is begrensd door zichtbare wegdata.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && ShowRoadBreakDemand)
                    {
                        <div class="legend-item">
                            <span class="legend-line road-break-demand-line"></span>
                            <div>
                                <strong>Pauzelaadvraag</strong>
                                <span>Oranje/rode wegvlakken; kleur en dikte lopen op met het aantal pauzepassages binnen het rijtijdvenster.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && ShowRoadHeat)
                    {
                        <div class="legend-item heat">
                            <span class="legend-gradient road-gradient"></span>
                            <div>
                                <strong>Wegdrukte</strong>
                                <span>Niet klikbare heatmap met losse concentratiepunten; daarom vaak meer resultaten dan wegvlakken.</span>
                            </div>
                        </div>
                    }

                    @if (!LegendCollapsed && SelectedDetail?.SelectionType == "stop")
                    {
                        <div class="legend-item heat">
                            <span class="legend-gradient selection-gradient"></span>
                            <div>
                                <strong>Vertrekroutes</strong>
                                <span>Groen naar rood: routes vanaf de gekozen stoplocatie na een vaste stilstandperiode.</span>
                            </div>
                        </div>
                    }
                </aside>
            </div>
        </section>

        @if (!HasActiveMapSelection)
        {
<RoadTablePanel Segments="@(Dashboard?.TopRoadSegments ?? [])" />
        }

        @if (SelectedDetail is not null)
        {
<SelectionDetailPanel Detail="SelectedDetail"
                                  RoadBreakDemand="SelectedRoadBreakDemand"
                                  IsBusy="IsBusy"
                                  OnRefresh="RefreshSelectedDetailAsync"
                                  OnOpenPopup="ShowDemandPopup" />
        }

        @if (!HasActiveMapSelection)
        {
            <section class="content-grid">
                <div class="table-panel">
                    <div class="panel-heading">
                        <h3>Top stoplocaties</h3>
                        <span>@(Dashboard?.TopStops.Length ?? 0) locaties</span>
                    </div>
                    <div class="table-scroll">
                        <table>
                            <thead>
                                <tr>
                                    <th>Locatie</th>
                                    <th>Voertuigen</th>
                                    <th>Stops</th>
                                    <th>Ritten</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Dashboard?.TopStops.Take(12) ?? [])
                                {
                                    <tr>
                                        <td>
                                            <strong>@(string.IsNullOrWhiteSpace(row.Name) ? row.Address : row.Name)</strong>
                                            <span>@row.Lat.ToString("0.000"), @row.Lon.ToString("0.000")</span>
                                        </td>
                                        <td>@row.Wagens</td>
                                        <td>@row.Stops</td>
                                        <td>@row.Trips</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="table-panel">
                    <div class="panel-heading">
                        <h3>Wegvlakken</h3>
                        <span>@UiFormat.RoadStatusLabel(Dashboard?.RoadStatus)</span>
                    </div>
                    <div class="table-scroll">
                        <table>
                            <thead>
                                <tr>
                                    <th>Segment</th>
                                    <th>Rijrichting</th>
                                    <th>Lengte</th>
                                    <th>Voertuigen</th>
                                    <th>Passages</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in Dashboard?.TopRoadSegments.Take(12) ?? [])
                                {
                                    <tr>
                                        <td><span>@row.Lat1.ToString("0.000"), @row.Lon1.ToString("0.000")</span></td>
                                        <td>@row.Direction</td>
                                        <td>@row.LengthKm.ToString("N1") km</td>
                                        <td>@row.UniqueWagens</td>
                                        <td>@row.Passes</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </section>

            <section class="simulation-panel">
                <div class="panel-heading">
                    <h3>Laadstrategie</h3>
                    <button @onclick="RunSimulationAsync" disabled="@IsBusy">Bereken laadniveau</button>
                </div>
                <div class="metric-row compact">
                    <div class="metric"><span>Laadmomenten</span><strong>@UiFormat.FormatNumber(Simulation?.ChargeEvents)</strong></div>
                    <div class="metric"><span>Ritten met laden</span><strong>@UiFormat.FormatNumber(Simulation?.TripsWithChargeEvent)</strong></div>
                    <div class="metric"><span>kWh</span><strong>@UiFormat.FormatNumber(Simulation?.TotalKwh)</strong></div>
                    <div class="metric"><span>Laaduren</span><strong>@UiFormat.FormatNumber(Simulation?.TotalChargeHours)</strong></div>
                </div>
            </section>
        }
    </main>
</div>

<DemandPopupModal Popup="DemandPopup" OnClose="CloseDemandPopup" />

@code {
    private MetadataResponse? Metadata { get; set; }
    private SummaryResponse? Summary { get; set; }
    private DashboardResponse? Dashboard { get; set; }
    private SimulationResponse? Simulation { get; set; }
    private SelectionDetailResponse? SelectedDetail { get; set; }
    private RoadBreakDemandDetailResponse? SelectedRoadBreakDemand { get; set; }
    private PowerProfileResponse? PowerProfiles { get; set; }
    private PowerLocationProfileResponse? SelectedPowerProfile { get; set; }
    private PowerDiagnosticsResponse? PowerDiagnostics { get; set; }
    private DatasetUploadResult? UploadResult { get; set; }
    private DotNetObjectReference<Home>? MapCallbacks { get; set; }
    private bool IsBusy { get; set; }
    private bool IsUploading { get; set; }
    private bool MapReady { get; set; }
    private bool LegendCollapsed { get; set; }
    private bool PendingSelectionScroll { get; set; }
    private string? SelectedDepotId { get; set; }
    private RoadSelection? SelectedRoad { get; set; }
    private StopLocationDetailRequest? SelectedStopLocation { get; set; }
    private VehicleDemandPopup? DemandPopup { get; set; }

    private string TransportMode { get; set; } = "Alles";
    private string DateFromText { get; set; } = "";
    private string DateToText { get; set; } = "";
    private string VervoerdersText { get; set; } = "";
    private string WagencodesText { get; set; } = "";
    private double MinDwellMin { get; set; }
    private int RoadThreshold { get; set; } = 1;
    private int RoadTopPercent { get; set; } = 1;
    private string ZeZoneMode { get; set; } = "all";
    private bool ShowStopHeat { get; set; } = true;
    private bool ShowMarkers { get; set; } = true;
    private bool ShowRoads { get; set; }
    private bool ShowRoadBreakDemand { get; set; }
    private bool ShowRoadHeat { get; set; }
    private bool ShowOvernight { get; set; } = true;
    private bool ShowStandplaatsen { get; set; }
    private bool ShowCharterStandplaatsen { get; set; }
    private bool ShowChargers { get; set; } = true;
    private int MinDepotVehicles { get; set; } = 5;
    private double ScenarioKwhPerKm { get; set; } = 1.2;
    private double ScenarioCapacityKwh { get; set; } = 590;
    private bool ScenarioMcsEnabled { get; set; }
    private double ScenarioTargetSocPct { get; set; } = 100;
    private double BreakWindowStartHours { get; set; } = 3.5;
    private double BreakWindowEndHours { get; set; } = 4.5;
    private double BreakDurationHours { get; set; } = 0.75;
    private int BreakDemandMinPassages { get; set; } = 1;
    private int BreakDemandTopPercent { get; set; } = 10;
    private double ShiftResetGapHours { get; set; } = 2.0;
    private double ChargerMinPowerKw { get; set; } = 350;
    private int ChargerMinConnectors { get; set; } = 1;
    private bool ChargerOnlyDedicated { get; set; }
    private bool ChargerAccessPublic { get; set; } = true;
    private bool ChargerAccessSemiPublic { get; set; } = true;
    private bool ChargerAccessPrivate { get; set; }
    private string? OpenLayerInfoId { get; set; }
    private double MaxVehicleKw => ScenarioMcsEnabled ? 1_500 : 400;
    private bool HasActiveMapSelection => SelectedDetail is not null;

    private sealed record MapLayerDef(string Id, string Label, string Info, Func<bool> Get, Action<bool> Set, bool Disclaimer = false);

    private MapLayerDef[]? _mapLayers;

    private MapLayerDef[] MapLayers => _mapLayers ??=
    [
        new("stopdrukte", "Stopdrukte",
            "Heatmap uit ritdata-stops. De kleur wordt zwaarder bij veel stops en/of lange stoptijd. Dit zijn operationele stops, niet automatisch standplaatsen: klanten, hubs en routepunten kunnen dus rood zijn zonder dat daar een wagenparkstandplaats ligt.",
            () => ShowStopHeat, value => ShowStopHeat = value),
        new("toplocaties", "Toplocaties",
            "Top stoplocaties uit dezelfde ritdata als Stopdrukte, gegroepeerd op afgeronde coordinaten. Een groter markerpunt betekent meer unieke voertuigen en/of meer stops op die plek.",
            () => ShowMarkers, value => ShowMarkers = value),
        new("wegvlakken", "Wegvlakken",
            "Klikbare paarse toplijnen met segment-identiteit. Ze zijn samengesteld uit wegpassages, begrensd door de zichtbare-wegdata filter, en openen een detailanalyse per aangeklikt wegvlak.",
            () => ShowRoads, value => ShowRoads = value),
        new("pauzelaadvraag", "Pauzelaadvraag",
            "Wegvlakken waar voertuigen volgens de rijtijd-teller tussen het ingestelde pauzevenster vallen. De topfilter rangschikt op aantal pauzepassages; kleur en dikte tonen ook dat aantal. De piek-MW blijft beschikbaar in het detail.",
            () => ShowRoadBreakDemand, value => ShowRoadBreakDemand = value),
        new("wegdrukte", "Wegdrukte",
            "Niet-klikbare heatmap van losse wegdruktepunten. Deze laag gebruikt dezelfde passagedrempel, maar toont veel meer concentratiepunten dan de begrensde klikbare wegvlakken.",
            () => ShowRoadHeat, value => ShowRoadHeat = value),
        new("vaste-stilstandlocaties", "Vaste stilstandlocaties",
            "Afgeleid uit lange stilstand- en overnacht-events in ritdata. Het vermogensprofiel toont de gevraagde publieke laadvraag op basis van de huidige voertuigscenario-instellingen.",
            () => ShowOvernight, value => ShowOvernight = value),
        new("standplaatsen", "Standplaatsen (PostNL-wagenpark)",
            "Depot/opstapplaats uit de wagenpark-Excel, gekoppeld of gegeocodeerd naar adressen. Deze laag kan afwijken van Stopdrukte omdat standplaatsen thuisbases zijn, terwijl stopdrukte ook klanten, hubs of routepunten kan zijn en filters op periode, vervoerder en voertuig meedoen. Review-markeringen vragen handmatige controle.",
            () => ShowStandplaatsen, value => ShowStandplaatsen = value, Disclaimer: true),
        new("charter-standplaatsen", "Charterstandplaatsen",
            "Fysieke standplaatsen van charters uit de aparte charter-Excel. Deze locaties zijn bedoeld als verwachte shift-startpunten waar charters met minimaal 90% state of charge vertrekken.",
            () => ShowCharterStandplaatsen, value => ShowCharterStandplaatsen = value, Disclaimer: true),
        new("laadlocaties", "Laadlocaties",
            "Externe publieke, semi-publieke en private HDV-laadlocaties. De zichtbare punten worden gefilterd op vermogen, stekkers, toegang en of een locatie gereserveerd is.",
            () => ShowChargers, value => ShowChargers = value),
    ];

