    private async Task RefreshSelectedDetailAsync()
    {
        if (SelectedDepotId is null && SelectedRoad is null && SelectedStopLocation is null)
        {
            await ClearSelectionHeatAsync();
            await ClearRoadSelectionAsync();
            return;
        }

        IsBusy = true;
        try
        {
            var filter = BuildFilter();
            if (SelectedDepotId is not null)
            {
                SelectedDetail = await Analysis.GetOvernightLocationDetailAsync(new OvernightLocationDetailRequest(filter)
                {
                    DepotId = SelectedDepotId,
                    Scenario = BuildScenario()
                });
            }
            else if (SelectedStopLocation is not null)
            {
                SelectedDetail = await Analysis.GetStopLocationDetailAsync(new StopLocationDetailRequest(filter)
                {
                    Lat = SelectedStopLocation.Lat,
                    Lon = SelectedStopLocation.Lon,
                    Label = SelectedStopLocation.Label,
                    RadiusKm = SelectedStopLocation.RadiusKm,
                    Scenario = BuildScenario()
                });
            }
            else if (SelectedRoad is not null)
            {
                SelectedDetail = await Analysis.GetRoadSelectionAsync(new RoadSelectionRequest(filter)
                {
                    Road = SelectedRoad,
                    Scenario = BuildScenario()
                });
                SelectedRoadBreakDemand = await Analysis.GetRoadBreakDemandDetailAsync(BuildRoadBreakDemandDetailRequest(SelectedRoad));
            }

            if (MapReady && SelectedDetail is not null && SelectedDetail.SelectionType == "stop")
            {
                await JS.InvokeVoidAsync("routePlannerMap.updateSelectionHeat", SelectedDetail.HeatPoints);
            }
            else
            {
                await ClearSelectionHeatAsync();
            }
        }
        finally
        {
            IsBusy = false;
        }
    }

    private async Task SetTransportModeAsync(string mode)
    {
        if (TransportMode == mode || IsBusy)
        {
            return;
        }

        TransportMode = mode;
        SelectedDetail = null;
        SelectedPowerProfile = null;
        DemandPopup = null;
        await ApplyFiltersAsync();
    }

