@namespace LaadinfrastructuurPlanner.Components.Panels

@if (Profiles is not null)
{
    <section class="table-panel power-profile-panel">
        <div class="panel-heading">
            <div>
                <h3>24-uurs vermogensprofiel</h3>
                <span>@TransportLabel · klik op een cel voor voertuigen</span>
            </div>
            <button @onclick="() => OnRefresh.InvokeAsync()" disabled="@IsBusy">Profiel bijwerken</button>
        </div>
        @if (!string.IsNullOrWhiteSpace(Profiles.Message))
        {
            <p class="selection-message">@Profiles.Message</p>
        }
        else
        {
            <div class="power-method-strip">
                <strong>Berekening</strong>
                <span>Per truck: @CapacityKwh.ToString("N0") kWh / stilstanduren, begrensd op @MaxVehicleKw.ToString("N0") kW voertuigacceptatie. Cellen tonen de hoogste uurpiek in de selectie.</span>
            </div>
            <div class="power-heatmap" aria-label="Standplaats per uur vermogensvraag">
                <div class="power-grid-corner"></div>
                @foreach (var hour in Enumerable.Range(0, 24))
                {
                    <span class="power-hour-label">@($"{hour:00}")</span>
                }
                @foreach (var profile in Profiles.Locations.Take(5))
                {
                    <button class="power-location-label" title="@profile.Address" @onclick="() => OnSelectLocation.InvokeAsync(profile.LocationId)">
                        @(string.IsNullOrWhiteSpace(profile.Name) ? profile.Address : profile.Name)
                    </button>
                    @foreach (var cell in profile.HourlyProfile.OrderBy(x => x.Hour))
                    {
                        <button class="power-cell"
                                style="@PowerCellStyle(cell.RequiredKw, Profiles.Locations)"
                                title="@($"{cell.Label}: {UiFormat.FormatPower(cell.RequiredKw)} · {cell.Vehicles:N0} voertuigen")"
                                @onclick="() => OnOpenPopup.InvokeAsync((profile, cell))">
                            <span>@(cell.RequiredKw > 0 ? UiFormat.FormatPower(cell.RequiredKw) : "")</span>
                        </button>
                    }
                }
            </div>
            <div class="power-profile-summary">
                @foreach (var profile in Profiles.Locations.Take(5))
                {
                    <button class="power-summary-row" @onclick="() => OnSelectLocation.InvokeAsync(profile.LocationId)">
                        <strong>@(string.IsNullOrWhiteSpace(profile.Name) ? profile.Address : profile.Name)</strong>
                        <span>@UiFormat.FormatPower(profile.PeakKw) piek</span>
                        <span>@profile.UniqueOwnVehicles.ToString("N0") eigen · @profile.UniqueCharterVehicles.ToString("N0") charter</span>
                    </button>
                }
            </div>
        }
        @if (Diagnostics is not null)
        {
            <p class="power-diagnostics">
                Datakwaliteit: @Diagnostics.ChargeWindowActions.ToString("N0") laadvensters,
                @Diagnostics.MissingLocationActions.ToString("N0") zonder bruikbare locatie,
                @Diagnostics.UnknownVehicleClassActions.ToString("N0") zonder eigen/charter-label.
            </p>
        }
    </section>
}

@if (Selected is not null)
{
    <section class="selection-panel compact-selection">
        <div class="panel-heading">
            <div>
                <h3>@(Selected.Profile?.Name ?? "Standplaatsprofiel")</h3>
                <span>Drill-down vermogensprofiel</span>
            </div>
        </div>
        @if (Selected.Profile is not null)
        {
            var profile = Selected.Profile;
            <div class="metric-row compact">
                <div class="metric"><span>Voertuigen</span><strong>@profile.UniqueVehicles.ToString("N0")</strong></div>
                <div class="metric"><span>Eigen</span><strong>@profile.UniqueOwnVehicles.ToString("N0")</strong></div>
                <div class="metric"><span>Charter</span><strong>@profile.UniqueCharterVehicles.ToString("N0")</strong></div>
                <div class="metric"><span>Piek</span><strong>@UiFormat.FormatPower(profile.PeakKw)</strong></div>
            </div>
            <div class="window-list">
                @foreach (var scenario in Selected.Scenarios)
                {
                    var peak = scenario.HourlyProfile.MaxBy(x => x.RequiredKw);
                    <div class="window-row">
                        <strong>@scenario.Year · @scenario.Mode</strong>
                        <span>factor @scenario.ScaleFactor.ToString("P0")</span>
                        <span>@(peak?.Label ?? "00:00")</span>
                        <span>@(peak is null ? "0 kW" : UiFormat.FormatPower(peak.RequiredKw))</span>
                    </div>
                }
            </div>
            <div class="power-report-grid">
                <div class="analysis-card power-report-card">
                    <div class="card-heading">
                        <strong>Uurprofiel huidige selectie</strong>
                        <span>@UiFormat.FormatPower(profile.HourlyProfile.Max(x => x.RequiredKw)) piek</span>
                    </div>
                    <div class="power-bars" aria-label="Uurprofiel geselecteerde standplaats">
                        @foreach (var hour in profile.HourlyProfile.OrderBy(x => x.Hour))
                        {
                            <button class="power-bar"
                                    style="@PowerBarStyle(hour.RequiredKw, profile.HourlyProfile)"
                                    title="@($"{hour.Label}: {UiFormat.FormatPower(hour.RequiredKw)} · {hour.Vehicles:N0} voertuigen")"
                                    @onclick="() => OnOpenPopup.InvokeAsync((profile, hour))">
                                <span>@hour.Hour.ToString("00")</span>
                                <i>@UiFormat.FormatPower(hour.RequiredKw)</i>
                            </button>
                        }
                    </div>
                </div>
                <div class="analysis-card power-report-card">
                    <div class="card-heading">
                        <strong>Dagpieken voor rapport</strong>
                        <span>@Selected.DailyMetrics.Length.ToString("N0") dagen</span>
                    </div>
                    <div class="table-scroll compact-scroll">
                        <table>
                            <thead>
                                <tr>
                                    <th>Datum</th>
                                    <th>Voertuigen</th>
                                    <th>Eigen</th>
                                    <th>Charter</th>
                                    <th>Gem. stilstand</th>
                                    <th>Piek</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var day in TopPowerDays(Selected.DailyMetrics))
                                {
                                    <tr>
                                        <td><strong>@day.Date.ToString("dd-MM-yyyy")</strong></td>
                                        <td>@day.UniqueVehicles.ToString("N0")</td>
                                        <td>@day.OwnVehicles.ToString("N0")</td>
                                        <td>@day.CharterVehicles.ToString("N0")</td>
                                        <td>@day.AvgDwellMin.ToString("N0") min</td>
                                        <td><strong>@UiFormat.FormatPower(day.PeakKw)</strong></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </section>
}

@code {
    [Parameter] public PowerProfileResponse? Profiles { get; set; }
    [Parameter] public PowerDiagnosticsResponse? Diagnostics { get; set; }
    [Parameter] public PowerLocationProfileResponse? Selected { get; set; }
    [Parameter] public bool IsBusy { get; set; }
    [Parameter] public string TransportLabel { get; set; } = "";
    [Parameter] public double CapacityKwh { get; set; }
    [Parameter] public double MaxVehicleKw { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }
    [Parameter] public EventCallback<string> OnSelectLocation { get; set; }
    [Parameter] public EventCallback<(PowerLocationProfile Profile, PowerHourlyCell Cell)> OnOpenPopup { get; set; }

    private static string PowerCellStyle(double requiredKw, IReadOnlyCollection<PowerLocationProfile> profiles)
    {
        var max = profiles.SelectMany(x => x.HourlyProfile).Select(x => x.RequiredKw).DefaultIfEmpty(0).Max();
        var intensity = max <= 0 ? 0 : Math.Clamp(requiredKw / max, 0, 1);
        var alpha = requiredKw <= 0 ? 0 : 0.14 + 0.76 * intensity;
        return $"--power-alpha:{alpha.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}";
    }

    private static string PowerBarStyle(double requiredKw, IReadOnlyCollection<PowerHourlyCell> hours)
    {
        var max = hours.Select(x => x.RequiredKw).DefaultIfEmpty(0).Max();
        var height = max <= 0 ? 2 : Math.Max(4, Math.Round(100 * requiredKw / max, 1));
        return $"--bar-height:{height.ToString("0.#", System.Globalization.CultureInfo.InvariantCulture)}%";
    }

    private static IEnumerable<PowerDailyMetric> TopPowerDays(IEnumerable<PowerDailyMetric> days)
    {
        return days
            .OrderByDescending(x => x.PeakKw)
            .ThenByDescending(x => x.UniqueVehicles)
            .ThenBy(x => x.Date)
            .Take(10);
    }
}
