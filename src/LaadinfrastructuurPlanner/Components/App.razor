<!DOCTYPE html>
<html lang="nl">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <ResourcePreloader />
    <link rel="preconnect" href="https://unpkg.com" />
    <link rel="stylesheet" href="https://unpkg.com/maplibre-gl@5.20.1/dist/maplibre-gl.css" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="@Assets["LaadinfrastructuurPlanner.styles.css"]" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
    <script>
      // Helper used by Blazor OnAfterRender: wait until the map scripts (defer-loaded in body)
      // have finished initializing window.routePlannerMap and window.maplibregl.
      window.__waitForPlannerMap = (timeoutMs) => new Promise((resolve, reject) => {
        const limit = typeof timeoutMs === "number" ? timeoutMs : 8000;
        const start = Date.now();
        const tick = () => {
          if (window.routePlannerMap && window.maplibregl) { resolve(); return; }
          if (Date.now() - start > limit) {
            reject(new Error(
              `Map JS not loaded after ${limit}ms (routePlannerMap=${typeof window.routePlannerMap}, maplibregl=${typeof window.maplibregl})`));
            return;
          }
          setTimeout(tick, 80);
        };
        tick();
      });
    </script>
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="https://unpkg.com/maplibre-gl@5.20.1/dist/maplibre-gl.js"></script>
    <script src="@Assets["plannerMap.js"]"></script>
    <script src="@Assets["plannerExport.js"]"></script>
    <script src="@Assets["_framework/blazor.web.js"]"></script>
</body>

</html>
