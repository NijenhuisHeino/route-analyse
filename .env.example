# Copy this file to `.env` and adjust if needed.
# The tool reads trip Excel files from DATA_DIR.

# Default: Google Drive PostNL project data folder (macOS)
DATA_DIR=/Users/johnnynijenhuis/Library/CloudStorage/GoogleDrive-info@nijenhuistrucksolutions.nl/Mijn Drive/Nijenhuis Truck Solutions/Bedrijven/Den Haag/PostNL/Project/Data analyse ritten

# Alternatively point to a local/external SSD folder:
# DATA_DIR=/Volumes/T9/PostNL/data

# Open Charge Map API key (free — register at https://openchargemap.org/site/develop/api).
# Used to show existing public fast chargers on the map.
OCM_API_KEY=
